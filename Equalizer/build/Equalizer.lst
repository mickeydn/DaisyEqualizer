  44:Equalizer.cpp **** void Equalizer::Init(int sampleRate)
  45:Equalizer.cpp **** {
  46:Equalizer.cpp **** 	sampleRate_ = sampleRate;
  47:Equalizer.cpp **** 
  48:Equalizer.cpp **** 	// KBE changed to update filters
  49:Equalizer.cpp **** 	// Setting default peak bands center frequency
  50:Equalizer.cpp **** 	m_EQParams[0].fc = 100.0;
  51:Equalizer.cpp **** 	m_EQParams[0].gain = 5.0;
  52:Equalizer.cpp **** 	m_EQParams[1].fc = 500.0;
  53:Equalizer.cpp **** 	m_EQParams[1].gain = 2.0; 
  54:Equalizer.cpp **** 	m_EQParams[2].fc = 2000.0;
  55:Equalizer.cpp **** 	m_EQParams[2].gain = 0.5; 
  56:Equalizer.cpp **** 	m_EQParams[3].fc = 8000.0;
  57:Equalizer.cpp **** 	m_EQParams[3].gain = 2.0; 
  58:Equalizer.cpp **** 
  59:Equalizer.cpp **** 	for (short band = 0; band < NUM_EQ_BANDS; band++)
  60:Equalizer.cpp **** 	{
  61:Equalizer.cpp **** 		m_IIRfilter[band].Init();
  62:Equalizer.cpp **** 	    //m_EQParams[band].gain = 1.0; // Default gain
  63:Equalizer.cpp **** 		m_EQParams[band].Q = 8.0; // Default Q
  64:Equalizer.cpp **** 		updateEQParameters(band);
  65:Equalizer.cpp **** 	}
  66:Equalizer.cpp **** }
  67:Equalizer.cpp **** 
  68:Equalizer.cpp **** float Equalizer::incParameter(short band, PARAMETER param, float delta)
ARM GAS  C:\Users\Mickey\AppData\Local\Temp\cc3AAka3.s 			page 13


  69:Equalizer.cpp **** {
  70:Equalizer.cpp **** 	// TODO change code to increment parameter for IIR filters (See slides) - call updateEQParamters
  71:Equalizer.cpp ****     //m_filterOn = true; // For test only
  72:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain + delta);
  73:Equalizer.cpp **** 	return m_EQParams[band].gain;
  74:Equalizer.cpp **** }
  75:Equalizer.cpp **** 
  76:Equalizer.cpp **** float Equalizer::decParameter(short band, PARAMETER param, float delta)
  77:Equalizer.cpp **** {
  78:Equalizer.cpp **** 	// TODO change code to decrement parameter for IIR filters - call updateEQParamters
  79:Equalizer.cpp ****     //m_filterOn = false; // For test only
  80:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain - delta);
  81:Equalizer.cpp **** 	return m_EQParams[band].gain;
  82:Equalizer.cpp **** }
  83:Equalizer.cpp **** 
  84:Equalizer.cpp **** void Equalizer::setParameter(short band, PARAMETER param, float value)
  85:Equalizer.cpp **** {
  86:Equalizer.cpp ****     bool update = false;
  87:Equalizer.cpp **** 
  88:Equalizer.cpp **** 	if (band < NUM_EQ_BANDS)
  89:Equalizer.cpp **** 	{
  90:Equalizer.cpp **** 		switch (param)
  91:Equalizer.cpp **** 		{
  92:Equalizer.cpp **** 			case PM_GAIN:
  93:Equalizer.cpp **** 				if (m_EQParams[band].gain != value) {
  94:Equalizer.cpp **** 					m_EQParams[band].gain = value;
  95:Equalizer.cpp **** 					update = true;
  96:Equalizer.cpp **** 				}
  97:Equalizer.cpp **** 			  break;
  98:Equalizer.cpp **** 			case PM_FREQ:
  99:Equalizer.cpp **** 				if (m_EQParams[band].fc != value) {
 100:Equalizer.cpp **** 					m_EQParams[band].fc = value;
 101:Equalizer.cpp **** 					update = true;
 102:Equalizer.cpp **** 				}
 103:Equalizer.cpp **** 			  break;
 104:Equalizer.cpp **** 			case PM_Q:
 105:Equalizer.cpp **** 				if (m_EQParams[band].Q != value) {
 106:Equalizer.cpp **** 					m_EQParams[band].Q = value;
 107:Equalizer.cpp **** 					update = true;
 108:Equalizer.cpp **** 				}
 109:Equalizer.cpp **** 			  break;
 110:Equalizer.cpp **** 		}
 111:Equalizer.cpp **** 		if (update) updateEQParameters(band);
 112:Equalizer.cpp **** 	}
 113:Equalizer.cpp **** }

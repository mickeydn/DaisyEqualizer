  34:Equalizer.cpp **** 
  35:Equalizer.cpp **** void Equalizer::Init(int sampleRate)
  36:Equalizer.cpp **** {
  37:Equalizer.cpp **** 	sampleRate_ = sampleRate;
  38:Equalizer.cpp **** 
  39:Equalizer.cpp **** 	// KBE changed to update filters
  40:Equalizer.cpp **** 	// Setting default peak bands center frequency
  41:Equalizer.cpp **** 	m_EQParams[0].fc = 100.0;
  42:Equalizer.cpp **** 	m_EQParams[0].gain = 5.0;
  43:Equalizer.cpp **** 	m_EQParams[1].fc = 500.0;
  44:Equalizer.cpp **** 	m_EQParams[1].gain = 2.0; 
  45:Equalizer.cpp **** 	m_EQParams[2].fc = 2000.0;
  46:Equalizer.cpp **** 	m_EQParams[2].gain = 0.5; 
  47:Equalizer.cpp **** 	m_EQParams[3].fc = 4000.0;
  48:Equalizer.cpp **** 	m_EQParams[3].gain = 2.0; 
  49:Equalizer.cpp **** 
  50:Equalizer.cpp **** 
  51:Equalizer.cpp **** 	for (short band = 0; band < NUM_EQ_BANDS; band++)
ARM GAS  C:\Users\micke\AppData\Local\Temp\ccVd6JTg.s 			page 5


  52:Equalizer.cpp **** 	{
  53:Equalizer.cpp **** 		m_EQParams[band].Q = 8.0; // Default Q
  54:Equalizer.cpp **** 
  55:Equalizer.cpp **** 		switch (BAND_TYPES[band])
  56:Equalizer.cpp **** 		{
  57:Equalizer.cpp **** 		case BAND_LOW_SHELF:
  58:Equalizer.cpp **** 			/* kode til hvis det er low shelf*/
  59:Equalizer.cpp **** 			m_LowShelfFilter.Init();
  60:Equalizer.cpp **** 			m_filters[band] = &m_LowShelfFilter;
  61:Equalizer.cpp **** 			break;
  62:Equalizer.cpp **** 
  63:Equalizer.cpp **** 		case BAND_PEAK_EQ:
  64:Equalizer.cpp **** 			/* kode til hvis det er peaking EQ*/
  65:Equalizer.cpp **** 			m_IIRfilter[band].Init();
  66:Equalizer.cpp **** 			m_filters[band] = &m_IIRfilter[band];
  67:Equalizer.cpp **** 			break;
  68:Equalizer.cpp **** 
  69:Equalizer.cpp **** 		case BAND_HIGH_SHELF:
  70:Equalizer.cpp **** 			/* kode til high shelf */
  71:Equalizer.cpp **** 			m_HighShelfFilter.Init();
  72:Equalizer.cpp **** 			m_filters[band] = &m_HighShelfFilter;
  73:Equalizer.cpp **** 			break;
  74:Equalizer.cpp **** 		}
  75:Equalizer.cpp **** 		updateEQParameters(band);
  76:Equalizer.cpp **** 	}
  77:Equalizer.cpp **** 	
  78:Equalizer.cpp **** }

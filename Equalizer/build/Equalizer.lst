  33:Equalizer.cpp **** 
  34:Equalizer.cpp **** void Equalizer::Init(int sampleRate)
  35:Equalizer.cpp **** {
  36:Equalizer.cpp **** 	sampleRate_ = sampleRate;
  37:Equalizer.cpp **** 
  38:Equalizer.cpp **** 	
  39:Equalizer.cpp **** 	// Setting default peak bands center frequency
  40:Equalizer.cpp **** 	m_EQParams[0].fc = 100.0;	//low shelf
  41:Equalizer.cpp **** 	m_EQParams[0].gain = 3.0;	//bass boost
  42:Equalizer.cpp **** 	m_EQParams[1].fc = 500.0;	//peak
  43:Equalizer.cpp **** 	m_EQParams[1].gain = 2.0;
  44:Equalizer.cpp **** 	m_EQParams[2].fc = 800.0;	//peak
  45:Equalizer.cpp **** 	m_EQParams[2].gain = 2.0;
  46:Equalizer.cpp **** 	m_EQParams[3].fc = 2000.0;	//peak
  47:Equalizer.cpp **** 	m_EQParams[3].gain = 2.0; 
  48:Equalizer.cpp **** 	m_EQParams[4].fc = 2800.0;	//peak
  49:Equalizer.cpp **** 	m_EQParams[4].gain = 0.5; 
  50:Equalizer.cpp **** 	m_EQParams[5].fc = 4000.0;	//high shelf
  51:Equalizer.cpp **** 	m_EQParams[5].gain = 2.0; 
ARM GAS  C:\Users\micke\AppData\Local\Temp\cc4B4FB9.s 			page 5


  52:Equalizer.cpp **** 
  53:Equalizer.cpp **** 
  54:Equalizer.cpp **** 	for (short band = 0; band < NUM_EQ_BANDS; band++)
  55:Equalizer.cpp **** 	{
  56:Equalizer.cpp **** 		m_EQParams[band].Q = 8.0; // Default Q
  57:Equalizer.cpp **** 
  58:Equalizer.cpp **** 		switch (BAND_TYPES[band])
  59:Equalizer.cpp **** 		{
  60:Equalizer.cpp **** 		case BAND_LOW_SHELF:
  61:Equalizer.cpp **** 			/* kode til hvis det er low shelf*/
  62:Equalizer.cpp **** 			m_LowShelfFilter.Init();
  63:Equalizer.cpp **** 			m_filters[band] = &m_LowShelfFilter;
  64:Equalizer.cpp **** 			break;
  65:Equalizer.cpp **** 
  66:Equalizer.cpp **** 		case BAND_PEAK_EQ:
  67:Equalizer.cpp **** 			/* kode til hvis det er peaking EQ*/
  68:Equalizer.cpp **** 			m_IIRfilter[band].Init();
  69:Equalizer.cpp **** 			m_filters[band] = &m_IIRfilter[band];
  70:Equalizer.cpp **** 			break;
  71:Equalizer.cpp **** 
  72:Equalizer.cpp **** 		case BAND_HIGH_SHELF:
  73:Equalizer.cpp **** 			/* kode til high shelf */
  74:Equalizer.cpp **** 			m_HighShelfFilter.Init();
  75:Equalizer.cpp **** 			m_filters[band] = &m_HighShelfFilter;
  76:Equalizer.cpp **** 			break;
  77:Equalizer.cpp **** 		}
  78:Equalizer.cpp **** 		updateEQParameters(band);
  79:Equalizer.cpp **** 	}
  80:Equalizer.cpp **** 	
  81:Equalizer.cpp **** }

  83:Equalizer.cpp **** float Equalizer::incParameter(short band, PARAMETER param, float delta)
  84:Equalizer.cpp **** {
  85:Equalizer.cpp **** 	// TODO change code to increment parameter for IIR filters (See slides) - call updateEQParamters
  86:Equalizer.cpp ****     //m_filterOn = true; // For test only
  87:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain + delta);
  88:Equalizer.cpp **** 	return m_EQParams[band].gain;
  89:Equalizer.cpp **** }
  90:Equalizer.cpp **** 
  91:Equalizer.cpp **** float Equalizer::decParameter(short band, PARAMETER param, float delta)
  92:Equalizer.cpp **** {
  93:Equalizer.cpp **** 	// TODO change code to decrement parameter for IIR filters - call updateEQParamters
  94:Equalizer.cpp ****     //m_filterOn = false; // For test only
  95:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain - delta);
  96:Equalizer.cpp **** 	return m_EQParams[band].gain;

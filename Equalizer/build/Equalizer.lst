  80:Equalizer.cpp **** float Equalizer::incParameter(short band, PARAMETER param, float delta)
  81:Equalizer.cpp **** {
  82:Equalizer.cpp **** 	// TODO change code to increment parameter for IIR filters (See slides) - call updateEQParamters
  83:Equalizer.cpp ****     //m_filterOn = true; // For test only
  84:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain + delta);
  85:Equalizer.cpp **** 	return m_EQParams[band].gain;
  86:Equalizer.cpp **** }
  87:Equalizer.cpp **** 
  88:Equalizer.cpp **** float Equalizer::decParameter(short band, PARAMETER param, float delta)
  89:Equalizer.cpp **** {
  90:Equalizer.cpp **** 	// TODO change code to decrement parameter for IIR filters - call updateEQParamters
  91:Equalizer.cpp ****     //m_filterOn = false; // For test only
  92:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain - delta);
  93:Equalizer.cpp **** 	return m_EQParams[band].gain;
  94:Equalizer.cpp **** }
  95:Equalizer.cpp **** 
  96:Equalizer.cpp **** void Equalizer::setParameter(short band, PARAMETER param, float value)
  97:Equalizer.cpp **** {
  98:Equalizer.cpp ****     bool update = false;
  99:Equalizer.cpp **** 
 100:Equalizer.cpp **** 	if (band < NUM_EQ_BANDS)
 101:Equalizer.cpp **** 	{
 102:Equalizer.cpp **** 		switch (param)
 103:Equalizer.cpp **** 		{
 104:Equalizer.cpp **** 			case PM_GAIN:
 105:Equalizer.cpp **** 				if (m_EQParams[band].gain != value) {
 106:Equalizer.cpp **** 					m_EQParams[band].gain = value;
 107:Equalizer.cpp **** 					update = true;
 108:Equalizer.cpp **** 				}
ARM GAS  C:\Users\micke\AppData\Local\Temp\ccVd6JTg.s 			page 6


 109:Equalizer.cpp **** 			  break;
 110:Equalizer.cpp **** 			case PM_FREQ:
 111:Equalizer.cpp **** 				if (m_EQParams[band].fc != value) {
 112:Equalizer.cpp **** 					m_EQParams[band].fc = value;
 113:Equalizer.cpp **** 					update = true;
 114:Equalizer.cpp **** 				}
 115:Equalizer.cpp **** 			  break;
 116:Equalizer.cpp **** 			case PM_Q:
 117:Equalizer.cpp **** 				if (m_EQParams[band].Q != value) {
 118:Equalizer.cpp **** 					m_EQParams[band].Q = value;
 119:Equalizer.cpp **** 					update = true;
 120:Equalizer.cpp **** 				}
 121:Equalizer.cpp **** 			  break;
 122:Equalizer.cpp **** 		}
 123:Equalizer.cpp **** 		if (update) updateEQParameters(band);
 124:Equalizer.cpp **** 	}
 125:Equalizer.cpp **** }

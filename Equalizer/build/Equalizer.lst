  36:Equalizer.cpp **** 
  37:Equalizer.cpp **** void Equalizer::Init()
  38:Equalizer.cpp **** {
  39:Equalizer.cpp **** 	Init(48000); // Default sample rate
  40:Equalizer.cpp **** }
  41:Equalizer.cpp **** 
  42:Equalizer.cpp **** void Equalizer::Init(int sampleRate)
  43:Equalizer.cpp **** {
  44:Equalizer.cpp **** 	sampleRate_ = sampleRate;
  45:Equalizer.cpp **** 
  46:Equalizer.cpp **** 	// KBE changed to update filters
  47:Equalizer.cpp **** 	// Setting default peak bands center frequency
  48:Equalizer.cpp **** 	m_EQParams[0].fc = 100.0;
  49:Equalizer.cpp **** 	m_EQParams[0].gain = 5.0;
  50:Equalizer.cpp **** 	m_EQParams[1].fc = 500.0;
  51:Equalizer.cpp **** 	m_EQParams[1].gain = 2.0; 
  52:Equalizer.cpp **** 	m_EQParams[2].fc = 2000.0;
  53:Equalizer.cpp **** 	m_EQParams[2].gain = 0.5; 
  54:Equalizer.cpp **** 	m_EQParams[3].fc = 8000.0;
  55:Equalizer.cpp **** 	m_EQParams[3].gain = 2.0; 
  56:Equalizer.cpp **** 
  57:Equalizer.cpp **** 	for (short band = 0; band < NUM_EQ_BANDS; band++)
  58:Equalizer.cpp **** 	{
  59:Equalizer.cpp **** 		m_IIRfilter[band].Init();
  60:Equalizer.cpp **** 	    //m_EQParams[band].gain = 1.0; // Default gain
  61:Equalizer.cpp **** 		m_EQParams[band].Q = 8.0; // Default Q
  62:Equalizer.cpp **** 		m_filters[band] = &m_IIRfilter[band];
  63:Equalizer.cpp **** 		updateEQParameters(band);
  64:Equalizer.cpp **** 	}
  65:Equalizer.cpp **** }
  66:Equalizer.cpp **** 
  67:Equalizer.cpp **** float Equalizer::incParameter(short band, PARAMETER param, float delta)
  68:Equalizer.cpp **** {
  69:Equalizer.cpp **** 	// TODO change code to increment parameter for IIR filters (See slides) - call updateEQParamters
  70:Equalizer.cpp ****     //m_filterOn = true; // For test only
  71:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain + delta);
  72:Equalizer.cpp **** 	return m_EQParams[band].gain;
  73:Equalizer.cpp **** }
  74:Equalizer.cpp **** 
  75:Equalizer.cpp **** float Equalizer::decParameter(short band, PARAMETER param, float delta)
  76:Equalizer.cpp **** {
  77:Equalizer.cpp **** 	// TODO change code to decrement parameter for IIR filters - call updateEQParamters
  78:Equalizer.cpp ****     //m_filterOn = false; // For test only
  79:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain - delta);
  80:Equalizer.cpp **** 	return m_EQParams[band].gain;
  81:Equalizer.cpp **** }
  82:Equalizer.cpp **** 
  83:Equalizer.cpp **** void Equalizer::setParameter(short band, PARAMETER param, float value)
  84:Equalizer.cpp **** {
  85:Equalizer.cpp ****     bool update = false;
  86:Equalizer.cpp **** 
  87:Equalizer.cpp **** 	if (band < NUM_EQ_BANDS)
  88:Equalizer.cpp **** 	{
  89:Equalizer.cpp **** 		switch (param)
ARM GAS  C:\Users\micke\AppData\Local\Temp\cciUrr5R.s 			page 8


  90:Equalizer.cpp **** 		{
  91:Equalizer.cpp **** 			case PM_GAIN:
  92:Equalizer.cpp **** 				if (m_EQParams[band].gain != value) {
  93:Equalizer.cpp **** 					m_EQParams[band].gain = value;
  94:Equalizer.cpp **** 					update = true;
  95:Equalizer.cpp **** 				}
  96:Equalizer.cpp **** 			  break;
  97:Equalizer.cpp **** 			case PM_FREQ:
  98:Equalizer.cpp **** 				if (m_EQParams[band].fc != value) {
  99:Equalizer.cpp **** 					m_EQParams[band].fc = value;
 100:Equalizer.cpp **** 					update = true;
 101:Equalizer.cpp **** 				}
 102:Equalizer.cpp **** 			  break;
 103:Equalizer.cpp **** 			case PM_Q:
 104:Equalizer.cpp **** 				if (m_EQParams[band].Q != value) {

  99:Equalizer.cpp **** void Equalizer::setParameter(short band, PARAMETER param, float value)
 100:Equalizer.cpp **** {
 101:Equalizer.cpp ****     bool update = false;
 102:Equalizer.cpp **** 
 103:Equalizer.cpp **** 	if (band < NUM_EQ_BANDS)
 104:Equalizer.cpp **** 	{
 105:Equalizer.cpp **** 		switch (param)
 106:Equalizer.cpp **** 		{
 107:Equalizer.cpp **** 			case PM_GAIN:
 108:Equalizer.cpp **** 				if (m_EQParams[band].gain != value) {
ARM GAS  C:\Users\micke\AppData\Local\Temp\cc4B4FB9.s 			page 6


 109:Equalizer.cpp **** 					m_EQParams[band].gain = value;
 110:Equalizer.cpp **** 					update = true;
 111:Equalizer.cpp **** 				}
 112:Equalizer.cpp **** 			  break;
 113:Equalizer.cpp **** 			case PM_FREQ:
 114:Equalizer.cpp **** 				if (m_EQParams[band].fc != value) {
 115:Equalizer.cpp **** 					m_EQParams[band].fc = value;
 116:Equalizer.cpp **** 					update = true;
 117:Equalizer.cpp **** 				}
 118:Equalizer.cpp **** 			  break;
 119:Equalizer.cpp **** 			case PM_Q:
 120:Equalizer.cpp **** 				if (m_EQParams[band].Q != value) {
 121:Equalizer.cpp **** 					m_EQParams[band].Q = value;
 122:Equalizer.cpp **** 					update = true;
 123:Equalizer.cpp **** 				}
 124:Equalizer.cpp **** 			  break;
 125:Equalizer.cpp **** 		}
 126:Equalizer.cpp **** 		if (update) updateEQParameters(band);
 127:Equalizer.cpp **** 	}

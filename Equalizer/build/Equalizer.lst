  36:Equalizer.cpp **** 
  37:Equalizer.cpp **** void Equalizer::Init(int sampleRate)
  38:Equalizer.cpp **** {
  39:Equalizer.cpp **** 	sampleRate_ = sampleRate;
  40:Equalizer.cpp **** 
  41:Equalizer.cpp **** 	// KBE changed to update filters
  42:Equalizer.cpp **** 	// Setting default peak bands center frequency
  43:Equalizer.cpp **** 	m_EQParams[0].fc = 100.0;
  44:Equalizer.cpp **** 	m_EQParams[0].gain = 5.0;
  45:Equalizer.cpp **** 	m_EQParams[1].fc = 500.0;
  46:Equalizer.cpp **** 	m_EQParams[1].gain = 2.0; 
  47:Equalizer.cpp **** 	m_EQParams[2].fc = 2000.0;
  48:Equalizer.cpp **** 	m_EQParams[2].gain = 0.5; 
  49:Equalizer.cpp **** 	m_EQParams[3].fc = 8000.0;
  50:Equalizer.cpp **** 	m_EQParams[3].gain = 2.0; 
  51:Equalizer.cpp **** 
  52:Equalizer.cpp **** 	for (short band = 0; band < NUM_EQ_BANDS; band++)
  53:Equalizer.cpp **** 	{
  54:Equalizer.cpp **** 		m_IIRfilter[band].Init();
  55:Equalizer.cpp **** 	    //m_EQParams[band].gain = 1.0; // Default gain
  56:Equalizer.cpp **** 		m_EQParams[band].Q = 8.0; // Default Q
  57:Equalizer.cpp **** 		m_filters[band] = &m_IIRfilter[band];
  58:Equalizer.cpp **** 		updateEQParameters(band);
  59:Equalizer.cpp **** 	}
  60:Equalizer.cpp **** }
  61:Equalizer.cpp **** 
  62:Equalizer.cpp **** float Equalizer::incParameter(short band, PARAMETER param, float delta)
  63:Equalizer.cpp **** {
  64:Equalizer.cpp **** 	// TODO change code to increment parameter for IIR filters (See slides) - call updateEQParamters
  65:Equalizer.cpp ****     //m_filterOn = true; // For test only
  66:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain + delta);
  67:Equalizer.cpp **** 	return m_EQParams[band].gain;
  68:Equalizer.cpp **** }
  69:Equalizer.cpp **** 
  70:Equalizer.cpp **** float Equalizer::decParameter(short band, PARAMETER param, float delta)
  71:Equalizer.cpp **** {
  72:Equalizer.cpp **** 	// TODO change code to decrement parameter for IIR filters - call updateEQParamters
  73:Equalizer.cpp ****     //m_filterOn = false; // For test only
  74:Equalizer.cpp ****     setParameter(band, param, m_EQParams[band].gain - delta);
  75:Equalizer.cpp **** 	return m_EQParams[band].gain;
  76:Equalizer.cpp **** }
  77:Equalizer.cpp **** 
  78:Equalizer.cpp **** void Equalizer::setParameter(short band, PARAMETER param, float value)
  79:Equalizer.cpp **** {
  80:Equalizer.cpp ****     bool update = false;
  81:Equalizer.cpp **** 
  82:Equalizer.cpp **** 	if (band < NUM_EQ_BANDS)
  83:Equalizer.cpp **** 	{
  84:Equalizer.cpp **** 		switch (param)
  85:Equalizer.cpp **** 		{
  86:Equalizer.cpp **** 			case PM_GAIN:
  87:Equalizer.cpp **** 				if (m_EQParams[band].gain != value) {
  88:Equalizer.cpp **** 					m_EQParams[band].gain = value;
  89:Equalizer.cpp **** 					update = true;
ARM GAS  C:\Users\micke\AppData\Local\Temp\cc52QvG4.s 			page 8


  90:Equalizer.cpp **** 				}
  91:Equalizer.cpp **** 			  break;
  92:Equalizer.cpp **** 			case PM_FREQ:
  93:Equalizer.cpp **** 				if (m_EQParams[band].fc != value) {
  94:Equalizer.cpp **** 					m_EQParams[band].fc = value;
  95:Equalizer.cpp **** 					update = true;
  96:Equalizer.cpp **** 				}
  97:Equalizer.cpp **** 			  break;
  98:Equalizer.cpp **** 			case PM_Q:
  99:Equalizer.cpp **** 				if (m_EQParams[band].Q != value) {
 100:Equalizer.cpp **** 					m_EQParams[band].Q = value;
 101:Equalizer.cpp **** 					update = true;
 102:Equalizer.cpp **** 				}
 103:Equalizer.cpp **** 			  break;
 104:Equalizer.cpp **** 		}
 105:Equalizer.cpp **** 		if (update) updateEQParameters(band);
 106:Equalizer.cpp **** 	}
 107:Equalizer.cpp **** }

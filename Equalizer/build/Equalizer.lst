 106:Equalizer.cpp **** 					update = true;
 107:Equalizer.cpp **** 				}
 108:Equalizer.cpp **** 			  break;
 109:Equalizer.cpp **** 		}
 110:Equalizer.cpp **** 		if (update) updateEQParameters(band);
 111:Equalizer.cpp **** 	}
 112:Equalizer.cpp **** }
